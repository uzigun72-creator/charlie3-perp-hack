{
  "name": "@charli3perp/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bash scripts/prune-contract-midnight-nested.sh",
    "build": "tsc -p tsconfig.json",
    "deploy": "tsx src/deploy-charli3perp-order.ts",
    "run-all": "tsx src/run-charli3perp-all.ts",
    "run-pipeline": "tsx src/run-pipeline-all.ts",
    "run-pipeline-split": "tsx src/run-pipeline-split-all.ts",
    "run-pipeline-split-slot": "tsx src/run-pipeline-split-slot.ts",
    "print-midnight-address": "tsx src/print-midnight-address.ts",
    "midnight-wallet-balance": "tsx src/midnight-wallet-balance.ts",
    "fund-local-undeployed": "tsx src/fund-local-undeployed.ts",
    "fund-derived-wallets": "tsx src/midnight-fund-derived-wallets.ts",
    "sync-derived-wallets": "tsx src/midnight-sync-derived-wallets.ts",
    "parallel-cli": "tsx src/midnight-parallel-cli.ts",
    "bench:parallel-pipeline": "env C3PERP_PIPELINE_BENCH_LOG=1 MIDNIGHT_PARALLEL_SCRIPT=run-pipeline MIDNIGHT_PARALLEL_BENCH_JSON=1 tsx src/midnight-parallel-cli.ts",
    "sync-bench": "tsx src/midnight-sync-bench.ts",
    "bench:pipeline": "env C3PERP_PIPELINE_BENCH_LOG=1 C3PERP_PIPELINE_BENCH_JSON=1 tsx src/run-pipeline-all.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@charli3perp/midnight-contract": "file:../contract",
    "bip39": "^3.1.0",
    "dotenv": "^16.4.7",
    "buffer": "^6.0.3",
    "rxjs": "^7.8.1",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.0",
    "patch-package": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
