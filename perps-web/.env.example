# Browser: leave empty when using Vite dev proxy to the API on :8791
# If 8791 is busy, set the API to another port and match the proxy:
#   PERPS_API_PORT=8792
#   VITE_API_PROXY_TARGET=http://127.0.0.1:8792
# For static hosting against a remote API, set e.g. VITE_API_URL=https://your-api.example.com
#
# Cardano `WALLET_MNEMONIC` (Preprod tADA wallet) is read from the repo-root `.env` by the API.
# You can override it here only if you set a non-empty value.
#
# Midnight (repo-root `.env`): full pipeline defaults to **five wallets × five contracts** (`run-pipeline-split`,
# parallel subprocesses in CLI). Explicit defaults (optional — orchestrator matches if omitted):
PERPS_MIDNIGHT_PARALLEL_CONTRACTS=1
MIDNIGHT_SPLIT_PARALLEL=1
# Repo root: `npm run midnight:split-parallel-smoke` — proves 5 workers run concurrently (no chain, ~2s wall).
# Set `PERPS_MIDNIGHT_PARALLEL_CONTRACTS=0` for legacy single-wallet `run-pipeline`.
# API defaults `MIDNIGHT_SYNC_TIMEOUT_MS=1200000` (20m) on spawned Midnight CLI if unset — avoids infinite indexer hang (override in repo-root `.env`).
# HD base for the five split workers: `PERPS_MIDNIGHT_SPLIT_BASE` (default = `PERPS_MIDNIGHT_WORKER_OFFSET`, usually 1) → indices base…base+4.
# API: order of work — default is Midnight txs first, then Cardano (Charli3 pull, then settlement anchor).
# Set `C3PERP_PARALLEL_MIDNIGHT_CHARLI3_PULL=1` in repo-root `.env` to run Midnight CLI + Charli3 pull at the same time (old behavior).
# API: `PERPS_PIPELINE_TIMING=1` logs wall times for oracle, Midnight CLI, Charli3 pull, settlement anchor (stderr).
# API: `PERPS_MIDNIGHT_CLI_MAX_MS` — wall-clock kill for `npm run run-pipeline*` (default 3600000 = 60m). Set `0` for unlimited.
# Cardano: default is **fast confirm** from submitted pull + anchor tx hashes only (no Blockfrost wait). Set
# `PERPS_REQUIRE_CARDANO_TX_VISIBILITY=1` to poll until txs appear on-chain before marking trades confirmed.
# Override script: `PERPS_MIDNIGHT_PIPELINE_SCRIPT=run-pipeline` or `run-pipeline-split`.
# `MIDNIGHT_RUN_MODE=order-only` = faster `run-all` only (no on-chain matching seal).
# HD worker index for trade pipeline + CLI (`MIDNIGHT_DERIVE_KEY_INDEX`, default 0). Set in repo-root `.env`.
# API-only: protect Midnight maintenance routes (`POST /api/midnight/fund-derived`, `parallel-cli`, job list):
#   PERPS_ADMIN_SECRET=your-long-random-secret
# Then: `curl -H "Authorization: Bearer $PERPS_ADMIN_SECRET" http://127.0.0.1:8791/api/midnight/setup`
VITE_API_URL=

# Tx links default to https://explorer.1am.xyz/tx/{hash} (1AM Explorer — Midnight & Cardano).
# Optional overrides (no trailing slash):
# EXPLORER_BASE=https://explorer.1am.xyz
# CARDANO_EXPLORER_BASE=https://explorer.1am.xyz
# MIDNIGHT_EXPLORER_BASE=https://explorer.1am.xyz

# DEV ONLY — exposes seed in the JS bundle. API must set ALLOW_INSECURE_MNEMONIC_FROM_CLIENT=1
# VITE_BIP39_MNEMONIC="word1 word2 ..."
#
# Margin pool (Aiken) on-chain actions in Account tab: set in repo-root `.env`:
# MARGIN_POOL_UI_ACTIONS=1
